{
  "name": "bio-ignicion",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/migrate-if-db.js && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke --project=chromium",
    "test:e2e:bug48": "playwright test tests/e2e/onboarding-to-multi-sessions.spec.ts --project=chromium",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "k6 run tests/load/k6-smoke.js",
    "typecheck": "tsc --noEmit",
    "analyze": "ANALYZE=true next build",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "node scripts/seed.js",
    "verify:audit": "node scripts/verify-audit.js",
    "verify:backup": "node scripts/verify-backup.js",
    "rotate:key": "node scripts/rotate-data-key.js",
    "sbom": "cyclonedx-npm --output-file sbom.json",
    "postinstall": "prisma generate || true"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@auth/prisma-adapter": "^2.7.4",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.55.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.57.0",
    "@opentelemetry/resources": "^1.30.0",
    "@opentelemetry/sdk-node": "^0.57.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@prisma/client": "^6.2.1",
    "@sentry/nextjs": "^10.49.0",
    "@simplewebauthn/browser": "^11.0.0",
    "@simplewebauthn/server": "^11.0.0",
    "@upstash/redis": "^1.34.3",
    "framer-motion": "^12.38.0",
    "ioredis": "^5.4.2",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^8.0.5",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "stripe": "^17.5.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.7",
    "@vitest/coverage-v8": "^4.1.5",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prisma": "^6.2.1",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
