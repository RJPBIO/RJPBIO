# ═══════════════════════════════════════════════════════════════
# BIO-IGNICIÓN — Environment template
# Copy to .env.local (dev) or set in Vercel/AWS (prod). NEVER commit.
# ═══════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es

# ─── Database (Postgres / Supabase) ───────────────────────────
# Supabase gives two URLs. Use the POOLED one (port 6543) for runtime
# and the DIRECT one (port 5432) for `prisma migrate`. Both required in prod.
# Leave DATABASE_URL empty in dev to use the in-memory adapter (src/server/db.js).
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# ─── Auth.js (NextAuth v5) ────────────────────────────────────
AUTH_SECRET=change-me-to-a-32-byte-hex-string
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# OIDC providers (optional per tenant; omit to disable)
AUTH_OKTA_ID=
AUTH_OKTA_SECRET=
AUTH_OKTA_ISSUER=
AUTH_AZURE_AD_ID=
AUTH_AZURE_AD_SECRET=
AUTH_AZURE_AD_TENANT_ID=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ─── Email (transactional) ────────────────────────────────────
EMAIL_FROM="BIO-IGNICIÓN <no-reply@bio-ignicion.app>"
POSTMARK_SERVER_TOKEN=

# ─── SMS (phone OTP sign-in) ──────────────────────────────────
# SMS_PROVIDER overrides auto-detection:
#   - "console" → prints OTP to server log (dev/staging only; NEVER prod)
#   - unset + all TWILIO_* set → Twilio
#   - unset + prod + Twilio missing → phone auth disabled (UI hides button)
# See src/lib/sms.js and src/app/api/auth/providers-available/route.js
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# ─── LLM Coach (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=
COACH_MODEL=claude-sonnet-4-6

# ─── Rate limit / cache (Upstash Redis) ───────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Crypto / KMS ─────────────────────────────────────────────
# 32-byte hex; used by server-side envelope encryption (src/server/kms.js)
DATA_KEY=
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1

# ─── Observability ────────────────────────────────────────────
OTEL_SERVICE_NAME=bio-ignicion
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_LOG_ENDPOINT=

# ─── Anti-bot ─────────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Feature flags ────────────────────────────────────────────
FF_COACH=true
FF_BILLING=true
FF_SCIM=true

# ─── Push (VAPID) ─────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@bio-ignicion.app
