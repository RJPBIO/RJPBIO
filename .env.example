# ═══════════════════════════════════════════════════════════════
# BIO-IGNICIÓN — Environment template
# Copy to .env.local (dev) or set in Vercel/AWS (prod). NEVER commit.
#
# Names below are the literal `process.env.X` strings the code reads.
# If you rename a key here, also update src/server/*.js / middleware.
# ═══════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────
NODE_ENV=development
APP_VERSION=1.0.0
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_DEFAULT_LOCALE=es
DEFAULT_TIMEZONE=America/Mexico_City

# ─── Database (Postgres / Supabase) ───────────────────────────
# Supabase gives two URLs. Use the POOLED one (port 6543) for runtime
# and the DIRECT one (port 5432) for `prisma migrate`. Both required in prod.
# Leave DATABASE_URL empty in dev to use the in-memory adapter (src/server/db.js).
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
# DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:5432/postgres
DATABASE_URL=
DIRECT_URL=

# ─── Auth.js (NextAuth v5) ────────────────────────────────────
# AUTH_SECRET: 32-byte hex (openssl rand -hex 32). Rotating invalidates sessions.
# AUTH_TRUST_HOST=1 only in prod behind a trusted proxy (Vercel sets automatically).
AUTH_SECRET=change-me-to-a-32-byte-hex-string
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
AUTH_COOKIE_NAME=

# OIDC providers (optional per tenant; omit pair to disable a button).
# These EXACT names are what src/server/auth.js reads — do not rename.
# The UI (src/app/api/auth/providers-available/route.js) hides buttons
# whose credentials aren't set, so partial config fails safe.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AZURE_AD_TENANT_ID=
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_ISSUER=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Magic-link provider — nodemailer URL (e.g. smtp://user:pass@smtp.postmarkapp.com:587).
# Empty = magic-link button hidden.
EMAIL_SERVER=

# ─── WebAuthn / Passkeys ──────────────────────────────────────
# RP_ID = the eTLD+1 of your origin. ORIGIN must include scheme and port.
# Dev defaults (localhost / http://localhost:3000) are baked in src/server/webauthn.js.
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=

# ─── Email (transactional) ────────────────────────────────────
EMAIL_FROM="BIO-IGNICIÓN <no-reply@bio-ignicion.app>"
POSTMARK_SERVER_TOKEN=

# ─── SMS (phone OTP sign-in) ──────────────────────────────────
# SMS_PROVIDER overrides auto-detection:
#   - "console" → prints OTP to server log (dev/staging only; NEVER prod)
#   - unset + all TWILIO_* set → Twilio
#   - unset + prod + Twilio missing → phone auth disabled (UI hides button)
# See src/lib/sms.js and src/app/api/auth/providers-available/route.js
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_OVERAGE=

# ─── LLM Coach (Anthropic) ────────────────────────────────────
ANTHROPIC_API_KEY=
COACH_MODEL=claude-sonnet-4-6

# ─── Rate limit / idempotency (Upstash Redis REST) ────────────
# Upstash console gives URL + token. Names used by the code are
# REDIS_URL / REDIS_TOKEN (not UPSTASH_*). Leave empty in dev — the
# code falls back to an in-memory counter.
REDIS_URL=
REDIS_TOKEN=

# ─── Crypto / KMS / Audit ─────────────────────────────────────
# DATA_KEY: 32-byte hex; used by envelope encryption (src/server/kms.js).
# AUDIT_HMAC_KEY: 32-byte hex; signs the append-only audit chain so
#   a rewrite-from-scratch still fails verify:audit.
# IMPERSONATION_KEY: 32-byte hex for impersonation token HMAC; falls
#   back to AUTH_SECRET if unset, but separate key is strongly preferred.
DATA_KEY=
AUDIT_HMAC_KEY=
IMPERSONATION_KEY=
AWS_KMS_KEY_ID=
AWS_REGION=us-east-1
# S3 bucket for long-term audit export (npm run verify:audit).
AUDIT_EXPORT_BUCKET=

# ─── Platform / ops access control ────────────────────────────
# CSV of emails with platform-admin (cross-org) capability. Empty = no-one.
PLATFORM_ADMINS=
# Where demo-request + lead webhooks land.
SALES_INBOX=
# API key for the sync endpoint (src/app/api/vitals, onboarding, etc).
BI_API_KEY=
# CSV of origins allowed for CORS preflight on /api/v1/*.
CORS_ALLOWED_ORIGINS=

# ─── Observability ────────────────────────────────────────────
OTEL_SERVICE_NAME=bio-ignicion
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_LOG_ENDPOINT=
NEXT_PUBLIC_LOG_LEVEL=info
NEXT_PUBLIC_LOG_SAMPLE=1

# ─── Anti-bot ─────────────────────────────────────────────────
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ─── Client-side integrations / secrets ───────────────────────
# Deeplink signing for web+bioign:// protocol handler.
NEXT_PUBLIC_DEEPLINK_SECRET=
# Sync endpoint exposed by the PWA (leave empty to disable sync).
NEXT_PUBLIC_SYNC_ENDPOINT=
# NOM-035: set to "1" only after the published DOF has been archived
# and the SHA-256 recorded in src/lib/nom35/*.
NEXT_PUBLIC_NOM35_DOF_VERIFIED=0

# ─── Feature flags ────────────────────────────────────────────
FF_COACH=true
FF_BILLING=true
FF_SCIM=true

# ─── Push (VAPID) ─────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:ops@bio-ignicion.app

# ─── Cron (Vercel Cron) ───────────────────────────────────────
# CRON_SECRET: opaque secret (e.g. openssl rand -hex 32) presented as
# `Authorization: Bearer ${CRON_SECRET}` by Vercel Cron invocations.
# Without it, cron endpoints reject all callers (defense in depth).
CRON_SECRET=

# ─── Coach LLM model override (Sprint S1.6) ───────────────────
# Optional global override for src/lib/coach-model.js. When unset,
# resolveCoachModel(plan) picks: FREE → Haiku, PRO+ → Sonnet,
# ENTERPRISE+COACH_OPUS_FOR_ENTERPRISE=1 → Opus.
COACH_MODEL=
COACH_OPUS_FOR_ENTERPRISE=

# ─── Wearable webhook secrets (S1.4 confirmed already in code) ─
WHOOP_WEBHOOK_SECRET=
OURA_WEBHOOK_SECRET=
GARMIN_WEBHOOK_SECRET=
APPLE_HEALTH_WEBHOOK_SECRET=
FITBIT_WEBHOOK_SECRET=
