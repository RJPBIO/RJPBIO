// BIO-IGNICIÓN — multi-tenant schema
// Postgres con Row-Level Security a nivel app (tenant_id en todas las tablas).

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // pooled (PgBouncer) — Vercel runtime
  directUrl = env("DIRECT_URL")    // direct connection — migrations only
}

// ─── Tenancy ────────────────────────────────────────────
model Org {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  region         Region        @default(US)
  plan           Plan          @default(FREE)
  ssoDomain      String?       @unique
  ssoProvider    String?       // okta | azure | google | saml
  ssoMetadata    Json?
  branding       Json?         // logo, colors, customDomain
  stripeCustomer String?       @unique
  stripeSub      String?
  seats          Int           @default(5)
  seatsUsed      Int           @default(0)
  dpaAccepted    DateTime?
  dunningState   String?       // null | "past_due" | "canceled" | "failed"
  graceUntil     DateTime?     // after sub cancel/payment_failed, keep data until
  trialEndsAt    DateTime?
  personal       Boolean       @default(false)  // auto-creado al signup, no invitable
  // Security policies (Sprint 7) — enforcement en middleware + auth callbacks.
  requireMfa           Boolean       @default(false)
  sessionMaxAgeMinutes Int?           // null = usar default global de NextAuth (8h)
  ipAllowlist          String[]      @default([])     // CIDR IPv4 (e.g. "10.0.0.0/8")
  ipAllowlistEnabled   Boolean       @default(false)
  // Sprint 14 — custom domain DNS verification (TXT challenge).
  customDomainVerified       Boolean   @default(false)
  customDomainVerifyToken    String?
  customDomainVerifiedAt     DateTime?
  customDomainLastCheckedAt  DateTime?
  // Sprint 10 — audit log retention policy (días). 30..2555.
  auditRetentionDays      Int           @default(365)
  // Sprint 10 polish — last-verified persistence para SOC2 evidence pack.
  auditLastVerifiedAt     DateTime?
  auditLastVerifiedStatus String?       // "verified" | "tampered" | null
  auditLastPrunedAt       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  memberships    Membership[]
  invitations    Invitation[]
  auditLogs      AuditLog[]
  webhooks       Webhook[]
  apiKeys        ApiKey[]
  integrations   Integration[]
  supportTickets SupportTicket[]
  impersonations Impersonation[]
  wearableEvents WearableEvent[]
  nom35Responses Nom35Response[]
  dsarRequests   DsarRequest[]   @relation("DsarOrg")
  @@index([region])
  @@index([dunningState])
  @@index([customDomainVerified])
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  emailVerified DateTime?
  phone        String?       @unique     // E.164 (+521234567890). Alternate identity for SMS-OTP sign-in.
  phoneVerified DateTime?
  name         String?
  image        String?
  locale       String        @default("es")
  timezone     String        @default("America/Mexico_City")
  mfaEnabled   Boolean       @default(false)
  mfaSecret    String?
  mfaVerifiedAt DateTime?                    // last successful MFA challenge
  mfaBackupCodes String[]    @default([])    // scrypt hashes; consumed on use
  mfaFailCount Int           @default(0)     // resets on success; drives lockout
  mfaLockedUntil DateTime?                   // 429 until this passes
  passkeyCredentials Json?   // [{ id, publicKey, counter, transports }]
  sessionEpoch Int           @default(0)     // Sprint 8: bump → invalidate all JWTs
  lastLoginAt  DateTime?
  lastSyncedAt DateTime?     // último sync de neuralState desde el PWA
  deletedAt    DateTime?     // GDPR Art. 17 soft-delete
  createdAt    DateTime      @default(now())
  memberships  Membership[]
  sessions     Session[]
  accounts     Account[]
  neuralState  Json?         // mirror del Zustand store del PWA — sync vía /api/sync/outbox
  supportTickets SupportTicket[]
  impersonatedBy Impersonation[] @relation("ImpersonationTarget")
  impersonationsAsActor Impersonation[] @relation("ImpersonationActor")
  nom35Responses Nom35Response[]
  trustedDevices TrustedDevice[]
  mfaResetRequests MfaResetRequest[]
  userSessions UserSession[]
  dsarRequests DsarRequest[] @relation("DsarRequester")
  dsarResolutions DsarRequest[] @relation("DsarResolver")
}

// Sprint 8 — DB-backed sessions para visibilidad + remote revoke con
// JWT-strategy. JWT callback crea row al signin; lazy validation chequea
// revokedAt antes de servir páginas sensibles (admin layout, API wrappers).
model UserSession {
  id          String   @id @default(cuid())
  userId      String
  jti         String   @unique
  ip          String?
  userAgent   String?
  label       String?
  createdAt   DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  expiresAt   DateTime
  revokedAt   DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([userId, revokedAt, expiresAt])
  @@index([expiresAt])
}

// Trusted-device cookie — lets a user skip MFA for 30 days on a specific
// browser after a successful challenge with "remember device" checked.
// Cookie value is random; only its sha256 is stored here. Rotate on expiry.
model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  label      String?   // UA-derived, shown in /settings/sessions
  ip         String?
  createdAt  DateTime @default(now())
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([expiresAt])
}

// Self-serve MFA reset ticket — created from /recover when user lost
// their device. Admin resolves from /admin/mfa-resets (or support desk).
model MfaResetRequest {
  id         String   @id @default(cuid())
  userId     String
  email      String
  reason     String?
  ip         String?
  userAgent  String?
  status     String   @default("pending") // pending | approved | denied
  createdAt  DateTime @default(now())
  resolvedAt DateTime?
  resolverId String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([status, createdAt])
  @@index([userId])
}

// SMS-OTP — OTP de 6 dígitos hasheado (HMAC), TTL corto, contador de
// intentos. Se borra al consumirse o al expirar. Clave por teléfono
// normalizado E.164; una fila activa por número.
model PhoneOtp {
  id         String   @id @default(cuid())
  phone      String   @unique
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  ip         String?
  createdAt  DateTime @default(now())
  @@index([expiresAt])
}

enum Role {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

model Membership {
  id            String   @id @default(cuid())
  userId        String
  orgId         String
  role          Role     @default(MEMBER)
  teamId        String?
  scimId        String?  @unique
  // Sprint 12 — SCIM soft-deactivation. null = active; non-null = deactivated.
  deactivatedAt DateTime?
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  org           Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team          Team?    @relation(fields: [teamId], references: [id])
  @@unique([userId, orgId])
  @@index([orgId, role])
  @@index([deactivatedAt])
}

model Team {
  id        String       @id @default(cuid())
  orgId     String
  name      String
  managerId String?
  members   Membership[]
  @@unique([orgId, name])
}

model Invitation {
  id        String   @id @default(cuid())
  orgId     String
  email     String
  role      Role     @default(MEMBER)
  token     String   @unique
  expiresAt DateTime
  acceptedAt DateTime?
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  @@index([orgId, email])
}

// ─── Auth (Auth.js compatible) ───────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  ip           String?
  ua           String?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId])
}

// ─── Auditoría (append-only, hash chain) ────────────────
model AuditLog {
  id         BigInt   @id @default(autoincrement())
  orgId      String
  actorId    String?
  actorEmail String?
  action     String   // "session.complete", "user.invite", "billing.subscribe"
  target     String?
  ip         String?
  ua         String?
  payload    Json?
  prevHash   String?
  hash       String
  ts         DateTime @default(now())
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  @@index([orgId, ts])
  @@index([action])
}

// ─── Sesiones neurales agregadas (para dashboards) ──────
model NeuralSession {
  id            String   @id @default(cuid())
  orgId         String
  userId        String
  teamId        String?
  protocolId    String
  durationSec   Int
  coherenciaDelta Float?
  moodPre       Int?
  moodPost      Int?
  completedAt   DateTime
  clientVersion String?
  stationId     String?
  slot          StationSlot?
  station       Station? @relation(fields: [stationId], references: [id])
  @@index([orgId, completedAt])
  @@index([orgId, teamId, completedAt])
  @@index([orgId, stationId, completedAt])
  @@index([orgId, slot, completedAt])
}

// ─── Tap-to-Ignite: estaciones físicas (QR + NFC) ───────
enum StationSlot {
  MORNING
  EVENING
  ADHOC
}

enum StationPolicy {
  ANY
  ENTRY_EXIT
  MORNING_ONLY
  EVENING_ONLY
}

model Station {
  id            String         @id @default(cuid())
  orgId         String
  label         String
  location      String?        // texto libre: "Recepción piso 3", "Escritorio María"
  policy        StationPolicy  @default(ENTRY_EXIT)
  signingKey    String         // HMAC secret por estación (rotable)
  active        Boolean        @default(true)
  lastTapAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  taps          StationTap[]
  sessions      NeuralSession[]
  @@index([orgId, active])
}

model StationTap {
  id        BigInt       @id @default(autoincrement())
  orgId     String
  stationId String
  userId    String?      // null = identidad anónima local
  anonId    String?      // hash estable de device keypair
  slot      StationSlot
  status    String       // "ok" | "rejected:expired" | "rejected:slot" | "rejected:sig" | "rejected:replay"
  nonce     String?      // nonce del URL firmado — UNIQUE(stationId, nonce) para replay guard
  ip        String?
  ua        String?
  ts        DateTime     @default(now())
  station   Station      @relation(fields: [stationId], references: [id], onDelete: Cascade)
  @@unique([stationId, nonce])
  @@index([orgId, ts])
  @@index([stationId, ts])
  @@index([orgId, userId, slot, ts])
}

// ─── Billing ─────────────────────────────────────────────
enum Plan {
  FREE
  PRO         // B2C personal — $9.99/mes, 1 seat
  STARTER     // B2B mid-market — $X/seat/mes
  GROWTH      // B2B premium — más features
  ENTERPRISE  // B2B enterprise — SAML, custom DPA, MSA
}

enum Region {
  US
  EU
  APAC
  LATAM
}

// Sprint 19 — Incident management (public status page + RSS).
enum IncidentStatus {
  investigating
  identified
  monitoring
  resolved
}

enum IncidentSeverity {
  minor
  major
  critical
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  body        String?
  status      IncidentStatus   @default(investigating)
  severity    IncidentSeverity
  components  String[]         @default([])
  creatorId   String?
  startedAt   DateTime         @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  updates     IncidentUpdate[]
  @@index([status, severity])
  @@index([resolvedAt])
  @@index([startedAt])
}

model IncidentUpdate {
  id          String           @id @default(cuid())
  incidentId  String
  status      IncidentStatus
  body        String
  authorId    String?
  createdAt   DateTime         @default(now())
  incident    Incident         @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  @@index([incidentId])
}

// Sprint 13 — DSAR (GDPR Art. 15 / 17 / 20)
enum DsarKind {
  ACCESS
  PORTABILITY
  ERASURE
}

enum DsarStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
  EXPIRED
}

model DsarRequest {
  id            String     @id @default(cuid())
  userId        String
  orgId         String?
  kind          DsarKind
  status        DsarStatus @default(PENDING)
  reason        String?
  resolverId    String?
  resolverNotes String?
  artifactUrl   String?
  ip            String?
  userAgent     String?
  requestedAt   DateTime   @default(now())
  resolvedAt    DateTime?
  expiresAt     DateTime
  createdAt     DateTime   @default(now())
  user          User       @relation(name: "DsarRequester", fields: [userId], references: [id], onDelete: Cascade)
  org           Org?       @relation(name: "DsarOrg", fields: [orgId], references: [id], onDelete: SetNull)
  resolver      User?      @relation(name: "DsarResolver", fields: [resolverId], references: [id], onDelete: SetNull)
  @@index([userId])
  @@index([orgId, status])
  @@index([status, expiresAt])
}

// ─── Webhooks ────────────────────────────────────────────
model Webhook {
  id         String   @id @default(cuid())
  orgId      String
  url        String
  secret     String
  // Sprint 17 — secret rotation overlap (zero-downtime).
  prevSecret           String?
  prevSecretExpiresAt  DateTime?
  secretRotatedAt      DateTime?
  events     String[] // ["session.completed", "member.added", …]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  deliveries WebhookDelivery[]
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  @@index([prevSecretExpiresAt])
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  status     Int?
  attempts   Int      @default(0)
  nextRetry  DateTime?
  deliveredAt DateTime?
  error      String?
  createdAt  DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  @@index([nextRetry])
}

model ApiKey {
  id         String    @id @default(cuid())
  orgId      String
  name       String
  hash       String    @unique
  prefix     String
  scopes     String[]
  lastUsedAt DateTime?
  // Sprint 15 — lifecycle.
  lastUsedIp String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  revokedAt  DateTime?
  org        Org       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  @@index([orgId])
  @@index([expiresAt])
}

// ─── Integrations (Slack, Teams, etc.) ──────────────────
model Integration {
  id        String   @id @default(cuid())
  orgId     String
  provider  String   // "slack" | "teams" | "okta" | "workday"
  config    Json
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  @@unique([orgId, provider])
}

// ─── Support tickets (in-app → notify admins) ───────────
enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

model SupportTicket {
  id        String         @id @default(cuid())
  orgId     String?
  userId    String?
  email     String         // fallback when unauthenticated
  subject   String
  body      String         @db.Text
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(NORMAL)
  tags      String[]
  ua        String?
  ip        String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  org       Org?           @relation(fields: [orgId], references: [id], onDelete: SetNull)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([orgId, status, createdAt])
  @@index([status, priority, createdAt])
}

// ─── Admin impersonation audit (who acted as whom) ──────
model Impersonation {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String   // the platform admin
  targetId   String   // the user being impersonated
  reason     String
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  expiresAt  DateTime // hard cap, enforced server-side
  ip         String?
  ua         String?
  org        Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  actor      User     @relation("ImpersonationActor", fields: [actorId], references: [id], onDelete: Cascade)
  target     User     @relation("ImpersonationTarget", fields: [targetId], references: [id], onDelete: Cascade)
  @@index([orgId, startedAt])
  @@index([actorId, startedAt])
  @@index([targetId, startedAt])
}

// ─── NOM-035 — Factores de riesgo psicosocial (MX) ──────
model Nom35Response {
  id           String   @id @default(cuid())
  orgId        String
  userId       String
  guia         String   @default("III")  // "I" | "II" | "III"
  answers      Json                        // { "1": 0..4, ... }
  total        Int
  nivel        String                      // nulo|bajo|medio|alto|muy_alto
  porDominio   Json
  porCategoria Json
  completedAt  DateTime @default(now())
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([orgId, completedAt])
  @@index([orgId, nivel, completedAt])
  @@index([userId, completedAt])
}

// ─── Wearable ingress (Whoop, Oura, Garmin, Apple Health) ──
model WearableEvent {
  id         String   @id @default(cuid())
  orgId      String?
  userId     String?
  provider   String   // "whoop" | "oura" | "garmin" | "apple" | "fitbit"
  kind       String   // "hrv" | "sleep" | "recovery" | "activity" | "webhook"
  payload    Json
  receivedAt DateTime @default(now())
  org        Org?     @relation(fields: [orgId], references: [id], onDelete: SetNull)
  @@index([provider, receivedAt])
  @@index([userId, provider, receivedAt])
}
